<?xml version="1.0" encoding="utf-8"?>
<System>
  <P Name="Location">[77, 254, 1547, 1172]</P>
  <P Name="Open">on</P>
  <P Name="ReportName">simulink-default.rpt</P>
  <P Name="SIDHighWatermark">17</P>
  <Block BlockType="SubSystem" Name="Analog Butterworth&#xA;LP Filter1" SID="14">
    <PortCounts in="1" out="1"/>
    <P Name="Position">[215, 23, 275, 67]</P>
    <P Name="ZOrder">1</P>
    <Mask>
      <Type>buttap</Type>
      <Display>plot(20*log10(w),20*log10(abs(h)))</Display>
      <Description>Analog Butterworth low pass filter.

(Requires Signal Processing Toolbox)</Description>
      <Initialization>[z,p,k]=buttap(MaskParam2); z=MaskParam1*z; p=MaskParam1*p; k=real(prod(-p)); [num,den]=zp2tf(z,p,k); w=logspace(log10(MaskParam1/10),log10(10*MaskParam1),20); h=freqs(num,den,w); </Initialization>
      <Help>Butterworth low pass filter using MATLAB&apos;s butter command.</Help>
      <MaskParameter Name="MaskParam1" Type="edit">
        <Prompt>Cutoff frequency (rad/sec)</Prompt>
        <Value>pi</Value>
      </MaskParameter>
      <MaskParameter Name="MaskParam2" Type="edit">
        <Prompt>Order</Prompt>
        <Value>10</Value>
      </MaskParameter>
    </Mask>
    <System Ref="system_14"/>
  </Block>
  <Block BlockType="SubSystem" Name="Impulse&#xA;Generator" SID="1">
    <PortCounts in="1" out="1"/>
    <P Name="Position">[140, 24, 180, 66]</P>
    <P Name="ZOrder">-1</P>
    <P Name="ShowPortLabels">none</P>
    <Mask>
      <Type>D-T interpolator</Type>
      <Display>plot(-10,-10,110,110,[0,50,50,60,60,100],[0,0,80,80,0,0])</Display>
      <Initialization>L=round(T/MaskParam2);</Initialization>
      <MaskParameter Name="T" Type="edit">
        <Prompt>Input sampling period:</Prompt>
        <Value>1</Value>
      </MaskParameter>
      <MaskParameter Name="MaskParam2" Type="edit">
        <Prompt>Pulse width:</Prompt>
        <Value>0.3</Value>
      </MaskParameter>
    </Mask>
    <System Ref="system_1"/>
  </Block>
  <Block BlockType="Mux" Name="Mux" SID="8">
    <PortCounts in="2" out="1"/>
    <P Name="Position">[335, 121, 365, 154]</P>
    <P Name="ZOrder">-2</P>
    <P Name="Inputs">2</P>
  </Block>
  <Block BlockType="Scope" Name="Scope" SID="9">
    <PortCounts in="1"/>
    <P Name="Position">[405, 125, 435, 155]</P>
    <P Name="ZOrder">-3</P>
