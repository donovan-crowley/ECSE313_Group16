  <Block BlockType="SignalGenerator" Name="Signal&#xA;Generator" SID="10">
    <PortCounts out="1"/>
    <P Name="Position">[35, 28, 80, 62]</P>
    <P Name="ZOrder">-4</P>
    <P Name="Amplitude">1.000000</P>
    <P Name="Frequency">0.8</P>
  </Block>
  <Block BlockType="SubSystem" Name="Spectrum&#xA;Analyzer" SID="11">
    <PortCounts in="1"/>
    <P Name="Position">[410, 25, 440, 65]</P>
    <P Name="ZOrder">-5</P>
    <P Name="CopyFcn">sfunyst([],[],[],&apos;CopyBlock&apos;)</P>
    <P Name="DeleteFcn">sfunyst([],[],[],&apos;DeleteBlock&apos;)</P>
    <P Name="LoadFcn">sfunyst([],[],[],&apos;LoadBlock&apos;)</P>
    <P Name="FontSize">12</P>
    <P Name="ShowPortLabels">none</P>
    <Mask>
      <Type>Spectrum analyzer.</Type>
      <Display>plot(0,0,100,100,[14,91,91,14,14],[86,86,40,40,86],[85,82,80,79,75,67,63,60,57,53,41,36,33,27,24],[49,50,53,50,49,51,54,66,54,50,50,52,81,51,49])</Display>
      <Help>EE438 Lab utility; See Prof. Bouman.</Help>
      <MaskParameter Name="N" Type="edit">
        <Prompt>Number of sample points:</Prompt>
        <Value>2048</Value>
      </MaskParameter>
      <MaskParameter Name="T_s" Type="edit">
        <Prompt>Sampling period (sec):</Prompt>
        <Value>0.05</Value>
      </MaskParameter>
      <MaskParameter Name="plot_period" Type="edit">
        <Prompt>Plotting Period (sec):</Prompt>
        <Value>10</Value>
      </MaskParameter>
    </Mask>
    <System Ref="system_11"/>
  </Block>
  <Line>
    <P Name="ZOrder">1</P>
    <P Name="Src">1#out:1</P>
    <P Name="Dst">14#in:1</P>
  </Line>
  <Line>
    <P Name="ZOrder">4</P>
    <P Name="Src">8#out:1</P>
    <P Name="Dst">9#in:1</P>
  </Line>
  <Line>
    <P Name="ZOrder">5</P>
    <P Name="Src">10#out:1</P>
    <P Name="Points">[20, 0]</P>
    <Branch>
      <P Name="ZOrder">6</P>
      <P Name="Points">[0, 100]</P>
      <P Name="Dst">8#in:2</P>
    </Branch>
    <Branch>
      <P Name="ZOrder">7</P>
      <P Name="Dst">1#in:1</P>
    </Branch>
  </Line>
  <Line>
    <P Name="ZOrder">8</P>
    <P Name="Src">14#out:1</P>
    <P Name="Points">[25, 0]</P>
    <Branch>
      <P Name="ZOrder">2</P>
      <P Name="Points">[0, 85]</P>
      <P Name="Dst">8#in:1</P>
    </Branch>
    <Branch>
      <P Name="ZOrder">3</P>
      <P Name="Dst">11#in:1</P>
    </Branch>
  </Line>
</System>

